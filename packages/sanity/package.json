{
	"name": "@opti/sanity",
	"private": true,
	"version": "1.0.0",
	"description": "Sanity CMS workspace for OptiHR",
	"main": "./index.ts",
	"scripts": {
		"dev": "sanity dev --turbopack --no-cache",
		"start": "sanity start",
		"build": "sanity build",
		"deploy": "sanity deploy",
		"deploy-graphql": "sanity graphql deploy",
